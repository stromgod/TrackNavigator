<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background">

    <!-- PART 1: SETUP UI -->
    <LinearLayout
        android:id="@+id/layoutSetup"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="visible">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginBottom="32dp"
            android:importantForAccessibility="no"
            android:scaleType="centerInside"
            android:src="@drawable/ic_hero_route"
            app:tint="?attr/colorPrimary" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.TrackNavigator.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            app:cardElevation="8dp"
            app:cardCornerRadius="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- GPS Status Indicator (Centered) -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="8dp">

                    <ProgressBar
                        android:id="@+id/progressGpsSetup"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:indeterminate="true"
                        android:visibility="visible" />

                    <ImageView
                        android:id="@+id/imgGpsCheckSetup"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_check_green"
                        android:visibility="gone" />
                </FrameLayout>

                <TextView
                    android:id="@+id/textDistToStart"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceSubtitle2"
                    android:textColor="?attr/colorPrimary"
                    android:gravity="center"
                    android:visibility="gone"
                    tools:text="Distance to start: 150m"
                    tools:visibility="visible" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPickGpx"
            style="@style/Widget.TrackNavigator.Button"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="20dp"
            android:text="@string/pick_gpx"
            app:icon="@drawable/ic_btn_folder"
            android:elevation="12dp"
            android:stateListAnimator="@null"
            android:translationZ="6dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartRace"
            style="@style/Widget.TrackNavigator.Button"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:enabled="false"
            android:text="@string/start_race"
            app:icon="@drawable/ic_btn_play"
            android:elevation="12dp"
            android:stateListAnimator="@null"
            android:translationZ="6dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackFromSetup"
            style="@style/Widget.TrackNavigator.Button.Text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/cancel_record"
            app:icon="@drawable/ic_btn_back" />
    </LinearLayout>

    <!-- PART 2: ACTIVE RACE UI -->
    <LinearLayout
        android:id="@+id/layoutActiveRace"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone"
        tools:visibility="visible">

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.TrackNavigator.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/textCheckpoint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceHeadline5"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold"
                    android:gravity="center"
                    tools:text="Checkpoint 3 / 10" />

                <TextView
                    android:id="@+id/textDeviation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:minHeight="72dp"
                    android:gravity="center"
                    android:padding="12dp"
                    android:textAppearance="?attr/textAppearanceHeadline6"
                    android:background="@android:color/transparent"
                    tools:background="#40FF0000"
                    tools:text="On Track" />

                <TextView
                    android:id="@+id/textCoords"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:textAppearance="?attr/textAppearanceBody2"
                    tools:text="Lat / Lon" />

                <TextView
                    android:id="@+id/textRaceAccuracy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="4dp"
                    android:gravity="center"
                    android:textAppearance="?attr/textAppearanceBody2"
                    tools:text="Accuracy: 3.2 m" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.TrackNavigator.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:id="@+id/raceProgressBlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:importantForAccessibility="yes"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="12dp"
                    android:text="@string/race_progress_title"
                    android:textAppearance="?attr/textAppearanceSubtitle1"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:importantForAccessibility="no"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:paddingEnd="12dp">

                        <TextView
                            android:id="@+id/textMarkerStart"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="top|start"
                            android:text="@string/race_marker_start"
                            android:textAppearance="?attr/textAppearanceBody2"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/textMarkerMiddle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical|start"
                            android:text="@string/race_marker_middle"
                            android:textAppearance="?attr/textAppearanceBody2" />

                        <TextView
                            android:id="@+id/textMarkerFinish"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|start"
                            android:text="@string/race_marker_finish"
                            android:textAppearance="?attr/textAppearanceBody2" />
                    </FrameLayout>

                    <FrameLayout
                        android:id="@+id/raceProgressTrack"
                        android:layout_width="32dp"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/race_progress_title">

                        <View
                            android:id="@+id/raceProgressBg"
                            android:layout_width="16dp"
                            android:layout_height="match_parent"
                            android:layout_gravity="center_horizontal"
                            android:background="@drawable/bg_race_progress_track"
                            android:importantForAccessibility="no" />

                        <View
                            android:id="@+id/raceProgressFill"
                            android:layout_width="16dp"
                            android:layout_height="0dp"
                            android:layout_gravity="top|center_horizontal"
                            android:background="@drawable/bg_race_progress_fill"
                            android:importantForAccessibility="no" />

                        <LinearLayout
                            android:layout_width="24dp"
                            android:layout_height="match_parent"
                            android:layout_gravity="center_horizontal"
                            android:importantForAccessibility="no"
                            android:orientation="vertical">
                            <View android:layout_width="24dp" android:layout_height="4dp" android:background="@drawable/bg_race_progress_tick" />
                            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
                            <View android:layout_width="24dp" android:layout_height="4dp" android:background="@drawable/bg_race_progress_tick" />
                            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
                            <View android:layout_width="24dp" android:layout_height="4dp" android:background="@drawable/bg_race_progress_tick" />
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/textRaceStage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textAppearance="?attr/textAppearanceBody2"
                    android:textColor="?attr/colorPrimary"
                    tools:text="First part of the track" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStopRace"
            style="@style/Widget.TrackNavigator.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/stop_race"
            app:icon="@drawable/ic_btn_stop" />
    </LinearLayout>
</FrameLayout>
