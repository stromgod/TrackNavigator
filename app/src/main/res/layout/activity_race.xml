<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- PART 1: SETUP UI -->
    <LinearLayout
        android:id="@+id/layoutSetup"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="visible">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="16dp"
            android:text="@string/module_race"
            android:textAppearance="@style/TextAppearance.TrackNavigator.Title" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.TrackNavigator.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/textSetupStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/race_status_idle"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />

                <TextView
                    android:id="@+id/textDistToStart"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="8dp"
                    android:textColor="?attr/colorPrimary"
                    android:visibility="gone"
                    tools:text="Distance to start: 150m"
                    tools:visibility="visible" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPickGpx"
            style="@style/Widget.TrackNavigator.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/pick_gpx"
            app:icon="@drawable/ic_btn_folder" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartGps"
            style="@style/Widget.TrackNavigator.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/start_gps"
            app:icon="@drawable/ic_btn_play" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartRace"
            style="@style/Widget.TrackNavigator.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:enabled="false"
            android:text="@string/start_race"
            app:icon="@drawable/ic_btn_play" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackFromSetup"
            style="@style/Widget.TrackNavigator.Button.Text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/cancel_record"
            app:icon="@drawable/ic_btn_back" />
    </LinearLayout>

    <!-- PART 2: ACTIVE RACE UI -->
    <LinearLayout
        android:id="@+id/layoutActiveRace"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:id="@+id/textActiveTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="16dp"
            android:text="@string/race_notif_title"
            android:textAppearance="@style/TextAppearance.TrackNavigator.Title" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.TrackNavigator.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/textCheckpoint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceHeadline5"
                    android:textColor="?attr/colorPrimary"
                    tools:text="Checkpoint 3 / 10" />

                <TextView
                    android:id="@+id/textDeviation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:minHeight="64dp"
                    android:gravity="center"
                    android:padding="12dp"
                    android:textAppearance="?attr/textAppearanceHeadline6"
                    tools:background="#40FF0000"
                    tools:text="On Track" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.TrackNavigator.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/textCoords"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textAppearance="?attr/textAppearanceBody2"
                    tools:text="Lat: 55.1234 Lon: 37.5678" />

                <TextView
                    android:id="@+id/textRaceAccuracy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textAppearance="?attr/textAppearanceBody2"
                    tools:text="Accuracy: 3.2m" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStopRace"
            style="@style/Widget.TrackNavigator.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/stop_race"
            app:icon="@drawable/ic_btn_stop" />
    </LinearLayout>
</FrameLayout>
