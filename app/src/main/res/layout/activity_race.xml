<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background">

    <!-- PART 1: SETUP UI -->
    <LinearLayout
        android:id="@+id/layoutSetup"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="visible">

        <!-- Logo at the top -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginBottom="32dp"
            android:importantForAccessibility="no"
            android:scaleType="centerInside"
            android:src="@drawable/ic_hero_route"
            app:tint="#FFFFFF" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.TrackNavigator.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            app:cardBackgroundColor="@color/md_theme_surface"
            app:strokeColor="@color/card_stroke"
            app:cardElevation="8dp"
            app:cardCornerRadius="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="8dp">

                    <ProgressBar
                        android:id="@+id/progressGpsSetup"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:indeterminate="true"
                        android:indeterminateTint="#FFFFFF"
                        android:visibility="visible" />

                    <ImageView
                        android:id="@+id/imgGpsCheckSetup"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_check_green"
                        android:visibility="gone" />
                </FrameLayout>

                <TextView
                    android:id="@+id/textDistToStart"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceSubtitle2"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:visibility="gone"
                    tools:text="Distance to start: 150m"
                    tools:visibility="visible" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPickGpx"
            style="@style/Widget.TrackNavigator.Button"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="20dp"
            android:text="@string/pick_gpx"
            android:textColor="@color/md_theme_onPrimary"
            android:textStyle="bold"
            app:backgroundTint="#FFFFFF"
            app:icon="@drawable/ic_btn_folder"
            app:iconTint="@color/md_theme_onPrimary"
            android:elevation="12dp"
            android:translationZ="6dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartRace"
            style="@style/Widget.TrackNavigator.Button"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:enabled="false"
            android:text="@string/start_race"
            android:textColor="@color/md_theme_onPrimary"
            android:textStyle="bold"
            app:backgroundTint="#FFFFFF"
            app:icon="@drawable/ic_btn_play"
            app:iconTint="@color/md_theme_onPrimary"
            android:elevation="12dp"
            android:translationZ="6dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackFromSetup"
            style="@style/Widget.TrackNavigator.Button.Text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/cancel_record"
            android:textColor="#FFFFFF"
            app:icon="@drawable/ic_btn_back"
            app:iconTint="#FFFFFF" />
    </LinearLayout>

    <!-- PART 2: ACTIVE RACE UI -->
    <LinearLayout
        android:id="@+id/layoutActiveRace"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone"
        tools:visibility="visible">

        <!-- Header -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginBottom="16dp"
            android:src="@drawable/ic_hero_route"
            app:tint="#FFFFFF" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.TrackNavigator.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/md_theme_surface"
            app:strokeColor="@color/card_stroke"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <!-- Direction Arrow -->
                <ImageView
                    android:id="@+id/imgDirectionArrow"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:src="@drawable/ic_direction_arrow"
                    android:scaleType="centerInside"
                    android:importantForAccessibility="no"
                    tools:tint="#4CAF50" />

                <TextView
                    android:id="@+id/textCheckpoint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:textAppearance="?attr/textAppearanceHeadline5"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    tools:text="Checkpoint 1/5" />

                <TextView
                    android:id="@+id/textDeviation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textAppearance="?attr/textAppearanceSubtitle1"
                    android:textColor="#FFCDD2"
                    tools:text="Deviation: 12m L" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Progress Card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.TrackNavigator.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/md_theme_surface"
            app:strokeColor="@color/card_stroke"
            app:cardElevation="6dp">

            <LinearLayout
                android:id="@+id/raceProgressBlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="12dp"
                    android:text="@string/race_progress_title"
                    android:textColor="#FFFFFF"
                    android:textAppearance="?attr/textAppearanceSubtitle1"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:paddingEnd="12dp">

                        <TextView
                            android:id="@+id/textMarkerStart"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="top|start"
                            android:text="@string/race_marker_start"
                            android:textColor="#FFFFFF"
                            android:textAppearance="?attr/textAppearanceBody2" />

                        <TextView
                            android:id="@+id/textMarkerMiddle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical|start"
                            android:text="@string/race_marker_middle"
                            android:textColor="#E0E0E0"
                            android:textAppearance="?attr/textAppearanceBody2" />

                        <TextView
                            android:id="@+id/textMarkerFinish"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|start"
                            android:text="@string/race_marker_finish"
                            android:textColor="#E0E0E0"
                            android:textAppearance="?attr/textAppearanceBody2" />
                    </FrameLayout>

                    <FrameLayout
                        android:id="@+id/raceProgressTrack"
                        android:layout_width="32dp"
                        android:layout_height="match_parent">

                        <View
                            android:id="@+id/raceProgressBg"
                            android:layout_width="16dp"
                            android:layout_height="match_parent"
                            android:layout_gravity="center_horizontal"
                            android:background="@drawable/bg_race_progress_track" />

                        <View
                            android:id="@+id/raceProgressFill"
                            android:layout_width="16dp"
                            android:layout_height="0dp"
                            android:layout_gravity="top|center_horizontal"
                            android:background="@drawable/bg_race_progress_fill" />
                    </FrameLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/textRaceStage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textAppearance="?attr/textAppearanceBody2"
                    android:textColor="#FFFFFF"
                    tools:text="Race in progress..." />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStopRace"
            style="@style/Widget.TrackNavigator.Button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/stop_race"
            android:textColor="@color/md_theme_onPrimary"
            android:textStyle="bold"
            app:backgroundTint="#FFFFFF"
            app:icon="@drawable/ic_btn_stop"
            app:iconTint="@color/md_theme_onPrimary"
            android:elevation="8dp" />
    </LinearLayout>
</FrameLayout>
