<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/md_theme_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Logo at the top -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginBottom="32dp"
            android:importantForAccessibility="no"
            android:scaleType="centerInside"
            android:src="@drawable/ic_hero_route"
            app:tint="#FFFFFF" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.TrackNavigator.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            app:cardBackgroundColor="@color/md_theme_surface"
            app:strokeColor="@color/card_stroke"
            app:cardElevation="8dp"
            app:cardCornerRadius="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- GPS Indicator (No text label as requested) -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="12dp">

                    <ProgressBar
                        android:id="@+id/progressGps"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:indeterminate="true"
                        android:indeterminateTint="#FFFFFF"
                        android:visibility="visible" />

                    <ImageView
                        android:id="@+id/imgGpsCheck"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_check_green"
                        app:tint="#FFFFFF"
                        android:visibility="gone" />
                </FrameLayout>

                <TextView
                    android:id="@+id/textCoords"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:paddingBottom="6dp"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textAppearance="?attr/textAppearanceBody2"
                    tools:text="Lat: 55.1234 Lon: 37.5678" />

                <TextView
                    android:id="@+id/textAccuracy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="16dp"
                    android:gravity="center"
                    android:textColor="#E0E0E0"
                    android:textAppearance="?attr/textAppearanceBody2"
                    tools:text="Accuracy: 3.2m" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="#40FFFFFF"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/textPointsCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceHeadline6"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    tools:text="Points: 12" />

                <TextView
                    android:id="@+id/textDistance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textAppearance="?attr/textAppearanceSubtitle2"
                    android:textColor="#E0E0E0"
                    android:gravity="center"
                    android:alpha="0.8"
                    tools:text="Distance: 1.45 km" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Pleasant White Buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddPoint"
            style="@style/Widget.TrackNavigator.Button"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="20dp"
            android:enabled="false"
            android:text="@string/add_control_point"
            android:textColor="@color/md_theme_onPrimary"
            app:backgroundTint="#FFFFFF"
            app:icon="@drawable/ic_btn_add_pin"
            app:iconTint="@color/md_theme_onPrimary"
            android:elevation="12dp"
            android:stateListAnimator="@null"
            android:translationZ="6dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFinish"
            style="@style/Widget.TrackNavigator.Button"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="20dp"
            android:enabled="false"
            android:text="@string/finish_track"
            android:textColor="@color/md_theme_onPrimary"
            app:backgroundTint="#FFFFFF"
            app:icon="@drawable/ic_btn_save_gpx"
            app:iconTint="@color/md_theme_onPrimary"
            android:elevation="12dp"
            android:stateListAnimator="@null"
            android:translationZ="6dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            style="@style/Widget.TrackNavigator.Button.Text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/cancel_record"
            android:textColor="#FFFFFF"
            app:icon="@drawable/ic_btn_back"
            app:iconTint="#FFFFFF" />
    </LinearLayout>
</ScrollView>
