<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingBottom="180dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Spacer instead of logo -->
            <View
                android:layout_width="match_parent"
                android:layout_height="48dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/layoutBotRecord"
                style="@style/Widget.TrackNavigator.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/imgBotRecord"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:importantForAccessibility="no"
                        android:scaleType="fitCenter" />

                    <TextView
                        android:id="@+id/textBotRecord"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:textColor="#FFFFFF"
                        android:textAppearance="?attr/textAppearanceBody1"
                        android:textStyle="bold"
                        android:text="Botik message" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.TrackNavigator.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardBackgroundColor="@color/md_theme_surface"
                app:strokeColor="@color/card_stroke"
                app:cardElevation="8dp"
                app:cardCornerRadius="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="12dp">

                        <ProgressBar
                            android:id="@+id/progressGps"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center"
                            android:indeterminate="true"
                            android:indeterminateTint="#FFFFFF"
                            android:visibility="visible" />

                        <ImageView
                            android:id="@+id/imgGpsCheck"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_check_green"
                            app:tint="#FFFFFF"
                            android:visibility="gone" />
                    </FrameLayout>

                    <!-- textCoords removed -->

                    <TextView
                        android:id="@+id/textAccuracy"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingBottom="16dp"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:textAppearance="?attr/textAppearanceBody1"
                        android:textStyle="bold"
                        tools:text="Высокая точность" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="#40FFFFFF"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/textPointsCount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceHeadline6"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        tools:text="Точек: 12" />

                    <TextView
                        android:id="@+id/textDistance"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textAppearance="?attr/textAppearanceSubtitle2"
                        android:textColor="#E0E0E0"
                        android:gravity="center"
                        android:alpha="0.8"
                        tools:text="Дистанция: 1.45 км" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Buttons Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="24dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddPoint"
            style="@style/Widget.TrackNavigator.Button"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginBottom="16dp"
            android:enabled="false"
            android:text="@string/add_control_point"
            android:textColor="@color/md_theme_onPrimary"
            android:textSize="18sp"
            android:textStyle="bold"
            app:backgroundTint="#FFFFFF"
            app:icon="@drawable/ic_btn_add_pin"
            app:iconTint="@color/md_theme_onPrimary"
            app:iconSize="28dp"
            android:elevation="12dp"
            android:translationZ="6dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFinish"
            style="@style/Widget.TrackNavigator.Button"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:enabled="false"
            android:text="@string/finish_track"
            android:textColor="@color/md_theme_onPrimary"
            android:textSize="18sp"
            android:textStyle="bold"
            app:backgroundTint="#FFFFFF"
            app:icon="@drawable/ic_btn_save_gpx"
            app:iconTint="@color/md_theme_onPrimary"
            app:iconSize="28dp"
            android:elevation="12dp"
            android:translationZ="6dp" />
    </LinearLayout>

    <!-- Top-right Exit/Cancel Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBack"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:padding="0dp"
        android:insetLeft="0dp"
        android:insetTop="0dp"
        android:insetRight="0dp"
        android:insetBottom="0dp"
        app:icon="@drawable/ic_btn_exit"
        app:iconTint="#FFFFFF"
        app:iconSize="32dp"
        app:iconPadding="0dp" />

</FrameLayout>
