<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background"
    android:padding="24dp">

    <!-- Top-right exit button (Small, icon-only) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnExit"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:padding="0dp"
        android:insetLeft="0dp"
        android:insetTop="0dp"
        android:insetRight="0dp"
        android:insetBottom="0dp"
        app:icon="@drawable/ic_btn_exit"
        app:iconTint="?attr/colorOnSurface"
        app:iconSize="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Walking person icon (Placeholder) -->
    <ImageView
        android:id="@+id/imgMainHero"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:importantForAccessibility="no"
        android:src="@drawable/ic_hero_route"
        app:layout_constraintTop_toBottomOf="@id/layoutBotMain"
        app:layout_constraintBottom_toTopOf="@+id/layoutButtons"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layoutBotMain"
        style="@style/Widget.TrackNavigator.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/btnExit"
        app:layout_constraintBottom_toTopOf="@id/imgMainHero"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/imgBotMain"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:importantForAccessibility="no"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/textBotMain"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:textColor="?attr/colorOnSurface"
                android:textAppearance="?attr/textAppearanceBody1"
                android:textStyle="bold"
                android:text="Botik message" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Voluminous White Buttons at the bottom -->
    <LinearLayout
        android:id="@+id/layoutButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRecord"
            style="@style/Widget.TrackNavigator.Button"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:text="@string/module_record"
            android:textColor="@color/md_theme_onPrimary"
            android:textSize="18sp"
            android:textStyle="bold"
            app:backgroundTint="?attr/colorSecondary"
            app:icon="@drawable/ic_btn_map_record"
            app:iconTint="@color/md_theme_onPrimary"
            app:iconSize="28dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRace"
            style="@style/Widget.TrackNavigator.Button"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="24dp"
            android:text="@string/module_race"
            android:textColor="@color/md_theme_onPrimary"
            android:textSize="18sp"
            android:textStyle="bold"
            app:backgroundTint="?attr/colorSecondary"
            app:icon="@drawable/ic_btn_flag_race"
            app:iconTint="@color/md_theme_onPrimary"
            app:iconSize="28dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
