<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background"
    android:padding="24dp">

    <!-- Top-right exit button (Small, icon-only) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnExit"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:padding="0dp"
        android:insetLeft="0dp"
        android:insetTop="0dp"
        android:insetRight="0dp"
        android:insetBottom="0dp"
        app:icon="@drawable/ic_btn_exit"
        app:iconTint="#FFFFFF"
        app:iconSize="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Walking person icon (Placeholder) -->
    <ImageView
        android:id="@+id/imgMainHero"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:importantForAccessibility="no"
        android:src="@drawable/ic_hero_route"
        app:tint="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/btnExit"
        app:layout_constraintBottom_toTopOf="@+id/layoutButtons"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Voluminous White Buttons at the bottom -->
    <LinearLayout
        android:id="@+id/layoutButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRecord"
            style="@style/Widget.TrackNavigator.Button"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:text="@string/module_record"
            android:textColor="@color/md_theme_onPrimary"
            android:textSize="18sp"
            android:textStyle="bold"
            app:backgroundTint="#FFFFFF"
            app:icon="@drawable/ic_btn_map_record"
            app:iconTint="@color/md_theme_onPrimary"
            app:iconSize="28dp"
            app:elevation="14dp"
            android:translationZ="10dp"
            android:stateListAnimator="@null" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRace"
            style="@style/Widget.TrackNavigator.Button"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="24dp"
            android:text="@string/module_race"
            android:textColor="@color/md_theme_onPrimary"
            android:textSize="18sp"
            android:textStyle="bold"
            app:backgroundTint="#FFFFFF"
            app:icon="@drawable/ic_btn_flag_race"
            app:iconTint="@color/md_theme_onPrimary"
            app:iconSize="28dp"
            app:elevation="14dp"
            android:translationZ="10dp"
            android:stateListAnimator="@null" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
