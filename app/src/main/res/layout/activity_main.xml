<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background"
    android:padding="32dp">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.25" />

    <!-- Voluminous White Buttons -->
    <LinearLayout
        android:id="@+id/layoutButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/guideline">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRecord"
            style="@style/Widget.TrackNavigator.Button"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:text="@string/module_record"
            android:textColor="@color/md_theme_onPrimary"
            android:textSize="18sp"
            android:textStyle="bold"
            app:backgroundTint="#FFFFFF"
            app:icon="@drawable/ic_btn_map_record"
            app:iconTint="@color/md_theme_onPrimary"
            app:iconSize="28dp"
            app:elevation="14dp"
            android:translationZ="10dp"
            android:stateListAnimator="@null" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRace"
            style="@style/Widget.TrackNavigator.Button"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="28dp"
            android:text="@string/module_race"
            android:textColor="@color/md_theme_onPrimary"
            android:textSize="18sp"
            android:textStyle="bold"
            app:backgroundTint="#FFFFFF"
            app:icon="@drawable/ic_btn_flag_race"
            app:iconTint="@color/md_theme_onPrimary"
            app:iconSize="28dp"
            app:elevation="14dp"
            android:translationZ="10dp"
            android:stateListAnimator="@null" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnExit"
        style="@style/Widget.TrackNavigator.Button.Outlined"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/exit_app"
        android:textColor="#FFFFFF"
        app:strokeColor="#FFFFFF"
        app:icon="@drawable/ic_btn_exit"
        app:iconTint="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
